# ─── Database ──────────────────────────────────────────────────────────────
# Direct Postgres connection string used by:
#   - migrations/run.ts (npm run migrate)
#   - lib/storage/clients.ts (worker process)
#
# Find this in Supabase dashboard → Project Settings → Database →
# Connection string → URI tab.
#
# For the worker on Railway: use the "Session" or "Transaction" pooler URL
# (port 6543) to respect Supabase connection limits.
# For migrations from your laptop: use the direct connection (port 5432).
#
# Format:
#   postgresql://postgres:<password>@<host>:<port>/postgres?sslmode=require
SUPABASE_DB_URL=

# Fallback used in local development. The migration runner and storage
# clients prefer SUPABASE_DB_URL but fall back to DATABASE_URL when unset.
DATABASE_URL=

# ─── Supabase API (for future Next.js read clients) ───────────────────────
# Not used today. Will be wired in P3 when the dashboard reads new tables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── External API keys ────────────────────────────────────────────────────
OPENAI_API_KEY=
TAAPI_KEY=
